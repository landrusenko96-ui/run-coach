GARMIN_BRIDGE_API_KEY=replace-with-a-long-random-bridge-key

# Local development can omit this; the bridge will use
# local-garmin-bridge/.garminconnect by default.
# Hosted VPS example:
# GARMIN_TOKEN_DIR=/var/lib/run-coach-garmin/.garminconnect
GARMIN_TOKEN_DIR=

# Local default is unset/local. Hosted VPS should set production.
# GARMIN_BRIDGE_ENV=production
GARMIN_BRIDGE_ENV=
