# Copy this file to .env.local, then fill in your own values.
# This file is for local development. Configure production values in Vercel.
# NEXT_PUBLIC means the value is allowed to be used in the browser.
# Garmin bridge variables are server-only. Use local values in .env.local and
# hosted private bridge values only in Vercel server env vars.

# Supabase Project URL. Example: https://abcxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Preferred for new Supabase client helpers.
# Usually starts with sb_publishable_.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback for older local setups.
# A legacy anon/public key still works, but the publishable key is preferred.
# Never put an sb_secret_ key, service_role key, access token, or database password here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key for trusted backend tasks, such as Strava token writes
# and Strava webhook processing.
# Keep this server-only. Do not add NEXT_PUBLIC_, never log it, and never use it
# in browser/client components. This key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Intervals.icu planned-workout publishing.
# Keep these server-only. Do not add NEXT_PUBLIC_ to either value.
# Publishing currently reads the athlete ID from this server env value.
INTERVALS_ATHLETE_ID=
INTERVALS_API_KEY=

# Experimental Direct Garmin bridge.
# Keep all of these server-only. Do not add NEXT_PUBLIC_ to any Garmin value.
# Local development does not need the Cloudflare Access values.
GARMIN_BRIDGE_URL=http://127.0.0.1:8765
GARMIN_BRIDGE_API_KEY=
GARMIN_BRIDGE_ACCESS_CLIENT_ID=
GARMIN_BRIDGE_ACCESS_CLIENT_SECRET=
GARMIN_BRIDGE_REQUEST_TIMEOUT_MS=15000

# Must never exist:
# NEXT_PUBLIC_GARMIN_BRIDGE_API_KEY
# NEXT_PUBLIC_GARMIN_BRIDGE_ACCESS_CLIENT_SECRET
# NEXT_PUBLIC_GARMIN_*
# GARMIN_USERNAME
# GARMIN_PASSWORD
# GARMIN_COOKIES
# GARMIN_TOKENS
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY

# Strava OAuth import.
# Keep STRAVA_CLIENT_SECRET server-only. Do not add NEXT_PUBLIC_ to it.
# NEXT_PUBLIC_APP_URL is the base URL Strava redirects back to.
# Local example: http://localhost:3000
# Production example: https://your-production-domain.example
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=

# Strava webhook setup.
# Keep these server-only. Do not add NEXT_PUBLIC_ to either value and never log them.
# Localhost cannot receive Strava webhooks directly; use a deployed URL or tunnel later.
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_WEBHOOK_CALLBACK_URL=
