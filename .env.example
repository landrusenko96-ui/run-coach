# Copy this file to .env.local, then fill in your own Supabase values.
# NEXT_PUBLIC means the value is allowed to be used in the browser.

# Supabase Project URL. Example: https://abcxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use a Publishable key, usually starting with sb_publishable_.
# A legacy anon/public key also works.
# Never put an sb_secret_ key or service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
